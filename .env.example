# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HF_TOKEN=your_huggingface_token_here

# Brain Configuration
# Provider: anthropic | openrouter | hf
BRAIN_PROVIDER=anthropic

# Model to use as the main brain
# For anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001, etc.
# For openrouter: openai/gpt-4o, meta-llama/llama-3.3-70b-instruct, etc.
# For hf: huihui-ai/DeepSeek-R1-Distill-Qwen-32B-abliterated:featherless-ai, etc.
BRAIN_MODEL=claude-sonnet-4-6

# HuggingFace Inference Router (used when BRAIN_PROVIDER=hf)
HF_DEFAULT_MODEL=huihui-ai/DeepSeek-R1-Distill-Qwen-32B-abliterated:featherless-ai

# Brain mode: native (API tool calling) | tags (XML tag pass-through for non-tool models)
BRAIN_MODE=native

# Fast/cheap model for simple tasks and routing decisions
# For anthropic provider: claude-haiku-4-5-20251001
# For openrouter: meta-llama/llama-3.1-8b-instruct, openai/gpt-4o-mini, etc.
FAST_MODEL=claude-haiku-4-5-20251001

# Model for routing decisions (can be same as FAST_MODEL)
ROUTER_MODEL=claude-haiku-4-5-20251001

# Optional: OpenRouter app info (shown in OpenRouter dashboard)
OPENROUTER_APP_NAME=AgentHarness
OPENROUTER_APP_URL=https://github.com/your/repo

# Optional: Max iterations for the agentic loop (default: 10)
MAX_ITERATIONS=10

# Optional: Memory storage directory (default: ./memory)
MEMORY_DIR=./memory

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
