# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider API Keys — Anthropic, OpenAI, Moonshot (Kimi)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Brain Configuration
# Provider: anthropic | openai | moonshot
BRAIN_PROVIDER=anthropic

# Model to use as the main brain
# For anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001, etc.
# For openai:    gpt-4o, gpt-4o-mini, o3, etc.
# For moonshot:  kimi-k2-0711-preview, moonshot-v1-128k, etc.
BRAIN_MODEL=claude-sonnet-4-6

# Brain mode: native (API tool calling) | tags (XML tag pass-through)
BRAIN_MODE=native

# Moonshot (Kimi) base URL — use https://api.moonshot.cn/v1 for the China endpoint
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Fast/cheap model for simple tasks and routing decisions
FAST_MODEL=claude-haiku-4-5-20251001

# Model for routing decisions (can be same as FAST_MODEL)
ROUTER_MODEL=claude-haiku-4-5-20251001

# Long-context engine — Kimi K2 (~256K context). Requires MOONSHOT_API_KEY.
LONG_CONTEXT_MODEL=kimi-k2-0711-preview

# Council member models (council_consult queries all available in parallel)
COUNCIL_GPT_MODEL=gpt-4o
COUNCIL_KIMI_MODEL=kimi-k2-0711-preview

# Optional: Max iterations for the agentic loop (default: 10)
MAX_ITERATIONS=10

# Optional: Memory storage directory (default: ./memory)
MEMORY_DIR=./memory

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
